# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to version control!

aws_region      = "us-east-1"

environment     = "dev"

oracle_vm_ip    = "123.45.67.89" 

# Database configuration
db_instance_class = "db.t3.micro"
db_name          = "trading_db"
db_username      = "trading_admin"

# It's recommended to store the DB password in Secrets Manager. If you must supply it here for initial deployment, set it, then remove it from this file.
db_password      = "YOUR_DB_PASSWORD"

# Alert configuration
alert_email = "your-email@example.com"

# DynamoDB table name for Terraform state locking (create beforehand or let Terraform create it by setting this to the table name)
dynamodb_table = "terraform-locks-dev"